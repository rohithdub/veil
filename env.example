# VEIL Backend — Environment Configuration
# Copy this file to .env and fill in your values

# ── Security ──────────────────────────────────────────────────────────
# Auto-generated on first run if left blank (but won't persist across restarts)
VEIL_SECRET_KEY=your-super-secret-jwt-key-change-this

# ── Admin Account ─────────────────────────────────────────────────────
VEIL_ADMIN_USER=admin
VEIL_ADMIN_PASS=change-me-immediately

# ── AI Backend ────────────────────────────────────────────────────────
# Format: anthropic | openai
VEIL_AI_FORMAT=anthropic

# Anthropic (default)
VEIL_AI_URL=https://api.anthropic.com/v1/messages
VEIL_AI_MODEL=claude-sonnet-4-20250514
VEIL_AI_KEY=sk-ant-your-key-here

# ── OR OpenAI ─────────────────────────────────────────────────────────
# VEIL_AI_FORMAT=openai
# VEIL_AI_URL=https://api.openai.com/v1/chat/completions
# VEIL_AI_MODEL=gpt-4o-mini
# VEIL_AI_KEY=sk-your-openai-key

# ── OR Ollama (local, no key needed) ─────────────────────────────────
# VEIL_AI_FORMAT=openai
# VEIL_AI_URL=http://localhost:11434/v1/chat/completions
# VEIL_AI_MODEL=llama3
# VEIL_AI_KEY=

# ── OR Groq ───────────────────────────────────────────────────────────
# VEIL_AI_FORMAT=openai
# VEIL_AI_URL=https://api.groq.com/openai/v1/chat/completions
# VEIL_AI_MODEL=llama3-70b-8192
# VEIL_AI_KEY=gsk_your-groq-key

# ── Server ────────────────────────────────────────────────────────────
PORT=5000
TOKEN_TTL_HOURS=24
